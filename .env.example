# Calendly integration
PUBLIC_CALENDLY_URL=https://calendly.com/your-username

# Resend email service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare KV for waitlist storage
WAITLIST_KV_NAMESPACE=redocted-waitlist

# Plausible Analytics (optional)
PUBLIC_PLAUSIBLE_DOMAIN=redocted.com

# Feature flags
PUBLIC_FEATURE_WAITLIST=true
PUBLIC_FEATURE_TESTIMONIALS=false
